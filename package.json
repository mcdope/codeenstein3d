{
  "name": "codeenstein-3d",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Turn any codebase into a playable retro 3D shooter — every file, function, and comment becomes a level, enemy, or secret.",
  "homepage": "https://codeenstein3d.mcdope.org/",
  "license": "AGPL-3.0-or-later",
  "author": "Tobias Bäumer",
  "scripts": {
    "predev": "node scripts/fetch-online-wads.mjs",
    "dev": "vite",
    "prebuild": "node scripts/fetch-online-wads.mjs",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "verify:wad-parser": "node scripts/verify-wad-parser.mjs",
    "verify:wad-textures": "node scripts/verify-wad-textures.mjs",
    "verify:zip-reader": "node scripts/verify-zip-reader.mjs",
    "fetch:online-wads": "node scripts/fetch-online-wads.mjs",
    "verify:campaign": "node scripts/verify-demo-campaign.mjs",
    "verify:campaign:playthrough": "node scripts/verify-campaign-playthrough.mjs",
    "generate:default-highscore": "node scripts/generate-default-highscore.mjs",
    "balancing:telemetry": "node scripts/run-balancing-telemetry.mjs",
    "balancing:watch": "node scripts/watch-bot-sessions.mjs",
    "balancing:scan": "CODEENSTEIN_TELEMETRY_ANOMALY_SCAN=1 CODEENSTEIN_TELEMETRY_LEVEL_LIMIT=8 CODEENSTEIN_TELEMETRY_ATTEMPT_CAP=5 CODEENSTEIN_TELEMETRY_DIFFICULTY=normal CODEENSTEIN_TELEMETRY_CONCURRENCY=6 node scripts/run-balancing-telemetry.mjs",
    "balancing:campaign": "node scripts/run-balancing-campaign.mjs",
    "perf:bench": "node scripts/run-perf-benchmark.mjs",
    "perf:report": "node scripts/build-perf-report.mjs",
    "poc:cross-browser-determinism": "node scripts/poc-cross-browser-determinism.mjs",
    "verify:multiplayer-server": "node scripts/verify-multiplayer-server.mjs",
    "verify:multiplayer-connect": "node scripts/verify-multiplayer-connect.mjs",
    "verify:multiplayer-netcode": "node scripts/verify-multiplayer-netcode.mjs",
    "verify:multiplayer-reconciliation": "node scripts/verify-multiplayer-reconciliation.mjs",
    "verify:multiplayer-disconnect": "node scripts/verify-multiplayer-disconnect.mjs",
    "verify:multiplayer-transition": "node scripts/verify-multiplayer-transition.mjs",
    "verify:multiplayer-multiguest": "node scripts/verify-multiplayer-multiguest.mjs",
    "verify:multiplayer-determinism": "node scripts/verify-multiplayer-determinism.mjs",
    "balancing:telemetry-multiplayer": "node scripts/run-balancing-telemetry-multiplayer.mjs",
    "balancing:scan-multiplayer": "CODEENSTEIN_MP_TELEMETRY_ANOMALY_SCAN=1 CODEENSTEIN_MP_TELEMETRY_PROFILE=Casual CODEENSTEIN_MP_TELEMETRY_DIFFICULTY=normal CODEENSTEIN_MP_TELEMETRY_PLAYER_COUNTS=2 CODEENSTEIN_MP_TELEMETRY_ATTEMPT_CAP=3 CODEENSTEIN_MP_TELEMETRY_QUALIFYING_TARGET=1 CODEENSTEIN_MP_TELEMETRY_DISCONNECT_SCENARIO=0 node scripts/run-balancing-telemetry-multiplayer.mjs",
    "balancing:campaign-multiplayer": "node scripts/run-balancing-campaign-multiplayer.mjs",
    "setup:ssh-lane-host": "node scripts/setup-ssh-lane-host.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@vitest/coverage-v8": "3.2.7",
    "esbuild": "^0.28.1",
    "jsdom": "^26.1.0",
    "playwright": "^1.61.1",
    "tree-sitter-bash": "^0.25.1",
    "tree-sitter-c": "^0.24.1",
    "tree-sitter-c-sharp": "^0.23.5",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.25.0",
    "tree-sitter-objc": "^3.0.2",
    "tree-sitter-php": "^0.24.2",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-ruby": "^0.23.1",
    "tree-sitter-rust": "^0.24.0",
    "tree-sitter-scala": "^0.24.0",
    "tree-sitter-typescript": "^0.23.2",
    "typescript": "^7.0.2",
    "vite": "^6.0.0",
    "vitest": "3.2.7"
  },
  "dependencies": {
    "web-tree-sitter": "^0.26.10"
  }
}
