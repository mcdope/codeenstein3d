#
# Copy to `.env` next to docker-compose.yml and fill in. `.env` is gitignored —
# it holds the TURN shared secret and the stats token.
#
#   cp .env.example .env

# ---------------------------------------------------------------------------
# Signaling server (always on)
# ---------------------------------------------------------------------------

# REQUIRED. The exact origin the game is served from — scheme + host, no
# trailing slash, no path. This is the CORS allowlist: get it wrong and every
# browser request from the game is rejected.
ALLOWED_ORIGIN=https://game.example.org

# Host port your reverse proxy forwards to. Published on 127.0.0.1 only.
SIGNALING_HOST_PORT=8787

# The container network. Its gateway is the address the signaling server
# trusts X-Forwarded-For from, so change it only if it collides with something
# else on the host — and change it here, not in one place.
SIGNALING_SUBNET=172.28.5.0/24

# Optional. Enables GET /stats and `--stats`. Unset ⇒ the endpoint does not
# exist (plain 404). Generate with: openssl rand -hex 32
STATS_TOKEN=

# ---------------------------------------------------------------------------
# TURN relay — only used when you start the stack with `--profile turn`
# ---------------------------------------------------------------------------

# The shared secret tying minted credentials to the relay. The SAME value is
# read by both services, so it is set once here. Generate with:
#   openssl rand -hex 32
# Leave empty to keep the relay disabled: the credentials route then 404s and
# clients fall back to STUN only.
TURN_SECRET=

# What the client is told to connect to. Comma-separated, most-preferred
# first. Must resolve to this host and match TURN_REALM.
TURN_URLS=turns:turn.example.org:5349,turn:turn.example.org:3478

# Minted credential lifetime, seconds.
TURN_TTL_SECONDS=3600

# The relay's public hostname — must match the certificate and TURN_URLS.
TURN_REALM=turn.example.org

# Ports. Leave TURN_TLS_PORT empty to run without TLS (plain 3478 only); TLS
# is what gets through networks that block everything but HTTPS. Open exactly
# these in the firewall, including the min–max UDP relay range:
#   ufw allow 3478/udp && ufw allow 3478/tcp && ufw allow 5349/tcp
#   ufw allow 49160:49200/udp
TURN_LISTENING_PORT=3478
TURN_TLS_PORT=5349
TURN_MIN_PORT=49160
TURN_MAX_PORT=49200

# Optional: bind the relay to specific interfaces (comma-separated). Empty
# means all of them — fine on a single-homed VPS, but if this box has an
# internal NIC, name the public IP here so the relay never listens on it.
TURN_LISTENING_IP=

# Optional: only needed if the host does NOT hold its public IP directly
# (cloud NAT). Set the public IP, or `auto` to resolve it over DNS at startup.
TURN_EXTERNAL_IP=

# Certificates for TURN_TLS_PORT. TURN_CERT_DIR is mounted read-only inside
# the container; the two file paths are relative to it. Point it at
# /etc/letsencrypt rather than live/<domain>, because live/ is symlinks into
# ../../archive that break if only the leaf directory is mounted.
TURN_CERT_DIR=/etc/letsencrypt
TURN_CERT_FILE=live/turn.example.org/fullchain.pem
TURN_PKEY_FILE=live/turn.example.org/privkey.pem

# The relay runs unprivileged (uid 65534), so it can only read the private key
# if it is in a group that may. On Debian/Ubuntu:
#   sudo addgroup --system ssl-cert          # usually already exists
#   sudo chgrp -R ssl-cert /etc/letsencrypt/archive /etc/letsencrypt/live
#   sudo chmod -R g+rX     /etc/letsencrypt/archive /etc/letsencrypt/live
#   getent group ssl-cert | cut -d: -f3      # ← the number to put below
TURN_CERT_GID=65533

# Abuse bounds. user-quota = concurrent allocations per credential,
# total-quota = across the whole relay, max-bps = per-session cap (empty =
# uncapped). Lower these if the relay shares a host with anything that matters.
TURN_USER_QUOTA=12
TURN_TOTAL_QUOTA=1200
TURN_MAX_BPS=

# Set to 1 to allow UDP relaying only — smaller attack surface, at the cost of
# clients on TCP-only networks.
TURN_NO_TCP_RELAY=0
